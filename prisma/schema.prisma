// Prisma schema for the Inlaze/Commizzion campaign analytics platform.
// Models the relationship between operators, campaigns, and their performance
// metrics, optimized for ROAS (Return on Ad Spend) time-series analysis.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// An operator (affiliate partner) who runs advertising campaigns.
/// In the iGaming context, operators are the brands/casinos being promoted.
model Operator {
  id        String     @id @default(cuid())
  name      String
  campaigns Campaign[]
  createdAt DateTime   @default(now())
}

/// A single advertising campaign belonging to an operator.
model Campaign {
  id         String             @id @default(cuid())
  name       String
  operator   Operator           @relation(fields: [operatorId], references: [id])
  operatorId String
  metrics    CampaignMetric[]
  createdAt  DateTime           @default(now())

  @@index([operatorId])
}

/// A time-series performance metric snapshot for a campaign.
/// ROAS (Return on Ad Spend) is recorded per snapshot, enabling
/// historical trend analysis and 7-day rolling averages.
model CampaignMetric {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  roas       Float
  recordedAt DateTime

  @@index([campaignId])
  @@index([recordedAt])
}
